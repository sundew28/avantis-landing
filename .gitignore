# Wordpress - ignore core, configuration, examples, uploads and logs.
# https://github.com/github/gitignore/blob/main/WordPress.gitignore

# =========================
# Node / npm dependencies
# =========================
node_modules/

# =========================
# Build output (npm compiled files)
# =========================
dist/
build/

# =========================
# npm logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Environment files (if used)
# =========================
.env
.env.local
.env.*.local

# =========================
# IDE / editor folders
# =========================
.vscode/
.idea/

# =========================
# Cache / temporary files
# =========================
.cache/
.tmp/
temp/
*.cache

# =========================
# WordPress (ONLY if inside full WP install)
# =========================
wp-content/uploads/
error_log